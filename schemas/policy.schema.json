{
  "$id": "policy.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["maxInputChars", "normalizeUnicode", "promptInjection", "redaction", "tools"],
  "properties": {
    "maxInputChars": { "type": "integer", "minimum": 1 },
    "normalizeUnicode": { "type": "boolean" },
    "promptInjection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled"],
      "properties": {
        "enabled": { "type": "boolean" },
        "patterns": { "type": "array", "items": { "type": "string" } }
      }
    },
    "redaction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled"],
      "properties": {
        "enabled": { "type": "boolean" },
        "patterns": { "type": "array", "items": { "type": "string" } }
      }
    },
    "tools": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allowlist": { "type": "array", "items": { "type": "string" } },
        "schemas": {
          "type": "object",
          "additionalProperties": { "type": "object" }
        }
      }
    }
  }
}
